<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <AssemblyName>ViewGrid</AssemblyName>
    <RootNamespace>ViewGrid</RootNamespace>
    <Version>1.0.52.2</Version>
    <AssemblyVersion>1.0.52.2</AssemblyVersion>
    <FileVersion>1.0.52.2</FileVersion>
    <InformationalVersion>1.0.52.2-community-preview-media-scenarios-compile-cleanup</InformationalVersion>
    <Company>Güner Taylan</Company>
    <Product>ViewGrid</Product>
    <Description>ViewGrid: prepared by Güner Taylan. Modern FastViewGridControl WinForms virtual list/grid control for .NET 10 with themed rendering, column filtering, glyph/icon cells, cell editing and large-data virtualization.</Description>
    <!-- Designer delegate provider properties are runtime-only. Attributes + ShouldSerialize methods prevent serialization; NoWarn avoids stale WinForms analyzer false positives in some VS previews. -->
    <NoWarn>$(NoWarn);WFO1000</NoWarn>
    <PackageId>ViewGrid.WinForms</PackageId>
    <Authors>Güner Taylan</Authors>
    <PackageTags>winforms;listview;grid;viewgrid;virtualization;filtering;glyph;net10</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <RepositoryType>git</RepositoryType>
    <RepositoryUrl Condition="'$(ViewGridRepositoryUrl)' != ''">$(ViewGridRepositoryUrl)</RepositoryUrl>
    <PackageProjectUrl Condition="'$(ViewGridRepositoryUrl)' != ''">$(ViewGridRepositoryUrl)</PackageProjectUrl>
  </PropertyGroup>
  <ItemGroup>
    <!-- .NET 10 / VS 2022 out-of-process WinForms Designer için SmartTag/ActionList desteği.
         System.Windows.Forms.Design eski .NET Framework designer API'sidir; net10'da Microsoft.WinForms.Designer.SDK gerekir. -->
    <PackageReference Include="Microsoft.WinForms.Designer.SDK" Version="1.6.0" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Core\ViewGridControl.bmp" />
    <EmbeddedResource Include="Tree\TreeViewGridControl.bmp" />
  </ItemGroup>
</Project>
